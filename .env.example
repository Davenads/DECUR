# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # server-side only — never expose to client

# ── Auth / Contact ───────────────────────────────────────────
RESEND_API_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── OAuth providers ──────────────────────────────────────────
# GitHub: https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:54321/auth/v1/callback (local) | https://<project>.supabase.co/auth/v1/callback (prod)
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# Google: https://console.cloud.google.com → Credentials → Create OAuth 2.0 Client
# Callback URL: http://localhost:54321/auth/v1/callback (local) | https://<project>.supabase.co/auth/v1/callback (prod)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# ── Integrations ─────────────────────────────────────────────
DISCORD_CONTRIBUTION_WEBHOOK_URL=

# ── ISR revalidation ─────────────────────────────────────────
REVALIDATE_SECRET=               # random hex string, shared with lib/revalidate.ts
NEXT_PUBLIC_SITE_URL=            # e.g. https://decur.app (used for ISR revalidation calls)

# ── Content generation scripts (dev only) ────────────────────
ANTHROPIC_API_KEY=
YOUTUBE_API_KEY=
